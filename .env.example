# ── Locitra Environment Variables Reference ──────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ── Site Configuration ────────────────────────────────────────────────────────
# Public site URL — used for CSRF origin validation and canonical URLs
NEXT_PUBLIC_SITE_URL=https://locitra.com

# ── Google Analytics 4 ────────────────────────────────────────────────────────
# Measurement ID from Google Analytics (starts with G-)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Brevo (Sendinblue) Email Service ─────────────────────────────────────────
# Create API key at: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here
# List ID from Brevo Contacts > Lists
BREVO_LIST_ID=3

# ── Contact Form ──────────────────────────────────────────────────────────────
# Admin email address that receives contact form submissions
ADMIN_EMAIL=your-email@gmail.com
# Optional CC email for contact form (can be a brand contact@ address)
CONTACT_CC_EMAIL=contact@locitra.com

# ── Bot Protection (Cloudflare Turnstile) — Future ────────────────────────────
# Get keys at: https://dash.cloudflare.com/turnstile
# Turnstile is free and provides frictionless bot protection
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_site_key_here
TURNSTILE_SECRET_KEY=your_secret_key_here

# ── Rate Limiting (Upstash Redis) — Future ────────────────────────────────────
# Get credentials at: https://console.upstash.com/
# Use the REST URL and token from your Redis database settings
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ── Comments (Giscus) — Optional ─────────────────────────────────────────────
# visit https://giscus.app to get your Giscus ids
NEXT_PUBLIC_GISCUS_REPO=
NEXT_PUBLIC_GISCUS_REPOSITORY_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=
NEXT_PUBLIC_GISCUS_CATEGORY_ID=